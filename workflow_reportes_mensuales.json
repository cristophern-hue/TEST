    {
      "id": "a1b2c3d4-0004-0004-0004-000000000004",
      "name": "Leer Mes Anterior",
      "type": "n8n-nodes-base.googleSheets",
      "typeVersion": 4.5,
      "position": [680, 420],
      "parameters": {
        "operation": "read",
        "documentId": {
          "__rl": true,
          "value": "REEMPLAZAR_CON_SPREADSHEET_ID",
          "mode": "id"
        },
        "sheetName": {
          "__rl": true,
          "value": "={{ $('Set Variables').first().json.mes_anterior }}",
          "mode": "name"
        },
        "filtersUI": {},
        "options": {}
      },
