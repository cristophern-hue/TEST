      },
      "credentials": {
        "googleSheetsOAuth2Api": {
          "id": "REEMPLAZAR_CON_CREDENTIAL_ID",
          "name": "Google Sheets account"
        }
      }
    },
    {
      "id": "a1b2c3d4-0007-0007-0007-000000000007",
      "name": "Loop Clientes",
      "type": "n8n-nodes-base.splitInBatches",
      "typeVersion": 3,
      "position": [1360, 300],
      "parameters": {
        "batchSize": 1,
        "options": {}
      }
    },
    {
      "id": "a1b2c3d4-0008-0008-0008-000000000008",
      "name": "Extraer File ID",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [1580, 300],
      "parameters": {
        "mode": "runOnceForEachItem",
        "jsCode": "// Extrae el file ID del link de Google Drive o Google Slides\n// Funciona con ambos formatos:\n//   https://drive.google.com/file/d/FILE_ID/view\n//   https://docs.google.com/presentation/d/FILE_ID/edit\n\nconst url = $input.item.json.link_ppt_anterior || '';\nconst match = url.match(/\\/d\\/([a-zA-Z0-9-_]+)/);\nconst fileId = match ? match[1] : null;\n\n// Construir nombre nuevo reemplazando el mes\nconst mesAnterior = $('Set Variables').first().json.mes_anterior;\nconst mesNuevo = $('Set Variables').first().json.mes_nuevo;\nconst nombreArchivo = url; // En el sheet, la celda puede tener el nombre mostrado\n// Si el link es una URL, el nombre lo sacaremos de la respuesta de Drive\n// Aquí guardamos el mes para el rename\n\nreturn {\n  json: {\n    ...$input.item.json,\n    file_id:    fileId,\n    tiene_link: fileId !== null,\n    mes_anterior: mesAnterior,\n    mes_nuevo:    mesNuevo\n  }\n};"
      }
    },
    {
      "id": "a1b2c3d4-0009-0009-0009-000000000009",
      "name": "Tiene Link?",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2.2,
      "position": [1800, 300],
      "parameters": {
        "options": {},
        "conditions": {
          "options": {
            "caseSensitive": true,
            "leftValue": "",
            "typeValidation": "strict"
          },
          "conditions": [
            {
              "id": "cond-tiene-link",
              "leftValue": "={{ $json.tiene_link }}",
              "rightValue": true,
              "operator": {
                "type": "boolean",
                "operation": "equals"
              }
            }
          ],
          "combinator": "and"
        }
      }
    },
    {
      "id": "a1b2c3d4-0010-0010-0010-000000000010",
      "name": "Copiar PPT Drive",
      "type": "n8n-nodes-base.googleDrive",
      "typeVersion": 3,
      "position": [2020, 180],
      "parameters": {
        "resource": "file",
        "operation": "copy",
        "fileId": {
          "__rl": true,
          "value": "={{ $json.file_id }}",
          "mode": "id"
        },
        "name": "={{ $json.nombre_original ? $json.nombre_original.replace($json.mes_anterior, $json.mes_nuevo) : 'Reporte - ' + $json.mes_nuevo }}",
        "driveId": {
          "__rl": true,
          "value": "MyDrive",
          "mode": "list"
        },
        "folderId": {
          "__rl": true,
          "value": "={{ $json.folder_id }}",
          "mode": "id"
        },
        "options": {}
      },
      "credentials": {
        "googleDriveOAuth2Api": {
          "id": "REEMPLAZAR_CON_CREDENTIAL_ID_DRIVE",
          "name": "Google Drive account"
        }
      }
    },
    {
      "id": "a1b2c3d4-0011-0011-0011-000000000011",
      "name": "Construir Fila",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [2240, 300],
      "parameters": {
        "mode": "runOnceForEachItem",
        "jsCode": "// Construye la fila para el nuevo tab del Sheet\n// Recibe items desde:\n//   - Copiar PPT Drive (tiene_link=true): $json.webViewLink disponible\n//   - Tiene Link? rama false (tiene_link=false): sin webViewLink\n\nconst item = $input.item.json;\n\n// El webViewLink viene del nodo Google Drive si se copió el archivo\nconst nuevoPptLink = item.webViewLink || '';\n\n// Parsear servicios\nconst servicios = (item.servicios || '').split(',').map(s => s.trim().toUpperCase());\n\nconst tieneSSEO   = servicios.includes('SEO');\nconst tienePAID  = servicios.includes('PAID');\nconst tieneEMAIL = servicios.includes('EMAIL');\nconst tieneREDES = servicios.includes('REDES');\n\nreturn {\n  json: {\n    'Clientes':                       item.cliente || '',\n    'Fecha Entrega Reporte [Interna]': '',\n    'Fecha Presentación a cliente':    '',\n    'Link ppt Mes':                    nuevoPptLink,\n    'Periodo para comparar':           item.periodo || '',\n    'Fecha de Activación Especial':    '',\n    'Estado SEO':    tieneSEO   ? 'Pendiente SEO'   : '',\n    'Estado PAID':   tienePAID  ? 'Pendiente PAID'  : '',\n    'Estado EMAIL':  tieneEMAIL ? 'Pendiente EMAIL' : '',\n    'Estado REDES':  tieneREDES ? 'Pendiente REDES' : '',\n    'Revisado por Mau':    false,\n    'Revisado por Sol':    false,\n    'Revisado por Glenda': false,\n    'Revisado por Lara':   false,\n    'Revisado por Cris':   false,\n    'Revisado por Meli':   false,\n    'Presentado': false,\n    'Enviado':    false,\n    'Notas':      ''\n  }\n};"
      }
    },
