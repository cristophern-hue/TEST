    {
      "id": "a1b2c3d4-0005-0005-0005-000000000005",
      "name": "Merge Datos",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [920, 300],
      "parameters": {
        "mode": "runOnceForAllItems",
        "jsCode": "// Lee Config Clientes y el tab del mes anterior\n// y los une por nombre de cliente\n\nconst configItems = $('Leer Config Clientes').all();\nconst prevMonthItems = $('Leer Mes Anterior').all();\n\n// Construir mapa: nombre cliente → config\nconst configMap = {};\nfor (const item of configItems) {\n  const cliente = (item.json['Cliente'] || '').trim();\n  if (cliente) {\n    configMap[cliente] = item.json;\n  }\n}\n\n// Unir con datos del mes anterior\nconst resultado = [];\nfor (const item of prevMonthItems) {\n  const cliente = (item.json['Clientes'] || '').trim();\n  if (!cliente) continue;\n\n  const cfg = configMap[cliente] || {};\n\n  resultado.push({\n    json: {\n      cliente:            cliente,\n      link_ppt_anterior:  item.json['Link ppt Mes'] || '',\n      folder_id:          cfg['Folder ID Drive'] || '',\n      servicios:          cfg['Servicios'] || '',\n      periodo:            cfg['Periodo Comparación'] || item.json['Periodo para comparar'] || ''\n    }\n  });\n}\n\nreturn resultado;"
      }
    },
    {
      "id": "a1b2c3d4-0006-0006-0006-000000000006",
      "name": "Crear Tab Nuevo Mes",
      "type": "n8n-nodes-base.googleSheets",
      "typeVersion": 4.5,
      "position": [1140, 300],
      "parameters": {
        "resource": "sheet",
        "operation": "create",
        "documentId": {
          "__rl": true,
          "value": "REEMPLAZAR_CON_SPREADSHEET_ID",
          "mode": "id"
        },
